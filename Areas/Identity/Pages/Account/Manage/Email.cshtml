@page
@model ASPMMA.Areas.Identity.Pages.Account.Manage.EmailModel

@{
    ViewData["Title"] = "Имейл настройки";
}

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-success mb-4">@Model.StatusMessage</div>
}

<section class="account-panel manage-inner-panel">
    <div class="admin-panel-head">
        <div>
            <span class="hero-kicker">Настройки на профила</span>
            <h2>Имейл адрес</h2>
            <p>Този имейл е свързан с профила ти в ММА Арена.</p>
        </div>
        <span class="badge-soft">Профил</span>
    </div>

    <div class="email-current">
        <span>Текущ имейл</span>
        <strong>@(string.IsNullOrWhiteSpace(Model.CurrentEmail) ? "-" : Model.CurrentEmail)</strong>
    </div>

    <form method="post" class="account-form">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="form-group">
            <label asp-for="Input.NewEmail" class="control-label"></label>
            <input asp-for="Input.NewEmail" class="form-control" autocomplete="email" />
            <span asp-validation-for="Input.NewEmail" class="text-danger"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-brand">Запази имейла</button>
            <a asp-page="./Index" class="action-link">Назад към профила</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
