@{
    var page = ViewContext.RouteData.Values["page"]?.ToString();
    string ActivePage(string target) => string.Equals(page, target, StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty;
}

<ul class="nav nav-pills flex-column manage-nav">
