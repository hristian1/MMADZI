@page
@model ASPMMA.Areas.Identity.Pages.Account.Manage.ChangePasswordModel

@{
    ViewData["Title"] = "Смяна на парола";
}

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-success mb-4">@Model.StatusMessage</div>
}

<section class="account-panel manage-inner-panel">
    <div class="admin-panel-head">
        <div>
            <span class="hero-kicker">Сигурност на профила</span>
            <h2>Смяна на парола</h2>
            <p>Обнови паролата за профила си в ММА Арена.</p>
        </div>
        <span class="badge-soft">Сигурност</span>
    </div>

    <div class="password-security-note">
        <strong>@Model.UserName</strong>
        <span>Използвай различна парола от тази в други сайтове.</span>
    </div>

    <form method="post" class="account-form">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="form-group">
            <label asp-for="Input.OldPassword" class="control-label"></label>
            <input asp-for="Input.OldPassword" class="form-control" autocomplete="current-password" />
            <span asp-validation-for="Input.OldPassword" class="text-danger"></span>
        </div>

        <div class="form-grid password-grid">
            <div class="form-group">
                <label asp-for="Input.NewPassword" class="control-label"></label>
                <input asp-for="Input.NewPassword" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Input.ConfirmPassword" class="control-label"></label>
                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>
        </div>

        <div class="password-rules">
            <span>Минимум 6 символа</span>
            <span>Не използвай очевидна парола</span>
            <span>Запази я само за този профил</span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-brand">Запази паролата</button>
            <a asp-page="./Index" class="action-link">Назад към профила</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
