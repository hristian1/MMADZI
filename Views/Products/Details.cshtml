@model ASPMMA.Data.Product

@{
    ViewData["Title"] = "Детайли за продукт";
    var imageUrl = string.IsNullOrWhiteSpace(Model.ImageUrl)
        ? "https://images.unsplash.com/photo-1517838277536-f5f99be501cd?auto=format&fit=crop&w=1000&q=80"
        : Model.ImageUrl;
}

<section class="section-head mb-4">
    <div>
        <h1>@Model.Name</h1>
        <p>@Model.CatalogNumber · @Model.Categorys?.CategoryName</p>
    </div>
    <div class="actions-wrap">
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-brand">Редакция</a>
        }
        <a asp-action="Index" class="btn btn-ghost-dark">Назад</a>
    </div>
</section>

@if (TempData["CartError"] is string cartError)
{
    <div class="alert alert-danger mb-4">@cartError</div>
}

@if (TempData["CartSuccess"] is string cartSuccess)
{
    <div class="alert alert-success mb-4">@cartSuccess</div>
}

<section class="record-card">
    <img src="@imageUrl" alt="@Model.Name" class="record-image" />
    <div class="record-body">
        <span class="eyebrow">Продукт</span>
        <h2>@Model.Name</h2>
        <p>@Model.Description</p>

        <dl class="record-list">
            <div>
                <dt>Категория</dt>
                <dd>@Model.Categorys?.CategoryName</dd>
            </div>
            <div>
                <dt>Размер</dt>
                <dd>@(string.IsNullOrWhiteSpace(Model.Size) ? "Няма" : Model.Size)</dd>
            </div>
            <div>
                <dt>Цена</dt>
                <dd>@Model.Price.ToString("0.##") лв.</dd>
            </div>
            <div>
                <dt>Наличност</dt>
                <dd>@Model.StockQuantity бр.</dd>
            </div>
            <div>
                <dt>Дата на добавяне</dt>
                <dd>@Model.CreatedAt.ToString("dd.MM.yyyy")</dd>
            </div>
        </dl>

        <div class="mt-4">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <form asp-controller="Carts" asp-action="AddToCart" method="post" class="stacked-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@Model.Id" />
                    <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                    <div class="form-grid">
                        <div class="form-group">
                            <label class="control-label">Количество</label>
                            <input name="quantity" type="number" min="1" max="@Math.Max(Model.StockQuantity, 1)" value="1" class="form-control" />
                        </div>
                    </div>
                    <div class="form-actions">
                        <button type="submit" class="btn btn-brand" @(Model.StockQuantity <= 0 ? "disabled" : null)>Добави в количка</button>
                    </div>
                </form>
            }
            else
            {
                <a asp-area="Identity" asp-page="/Account/Login" asp-route-returnUrl="@Url.Action("Details", "Products", new { id = Model.Id })" class="btn btn-brand">Влез, за да поръчаш</a>
            }
        </div>
    </div>
</section>
