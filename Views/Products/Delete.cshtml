@model ASPMMA.Data.Product

@{
    ViewData["Title"] = "Изтриване на продукт";
}

<section class="section-head mb-4">
    <div>
        <h1>Изтриване на продукт</h1>
        <p>Потвърди премахването на този артикул от каталога.</p>
    </div>
    <a asp-action="Index" class="btn btn-ghost-dark">Назад</a>
</section>

<section class="content-card danger-card">
    <span class="eyebrow">Потвърждение</span>
    <h2>@Model.Name</h2>
    <p class="form-note">@Model.Description</p>

    <dl class="record-list">
        <div>
            <dt>Каталожен номер</dt>
            <dd>@Model.CatalogNumber</dd>
        </div>
        <div>
            <dt>Категория</dt>
            <dd>@Model.Categorys?.CategoryName</dd>
        </div>
        <div>
            <dt>Цена</dt>
            <dd>@Model.Price.ToString("0.##") лв.</dd>
        </div>
        <div>
            <dt>Наличност</dt>
            <dd>@Model.StockQuantity бр.</dd>
        </div>
    </dl>

    <form asp-action="Delete" class="form-actions">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Изтрий продукта</button>
        <a asp-action="Index" class="action-link">Отказ</a>
    </form>
</section>
