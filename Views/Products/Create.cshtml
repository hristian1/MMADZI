@model ASPMMA.Data.Product

@{
    ViewData["Title"] = "Добавяне на продукт";
}

<section class="section-head mb-4">
    <div>
        <span class="hero-kicker">Админ редактор</span>
        <h1>Добавяне на продукт</h1>
        <p>Създай нов артикул в каталога с точни данни, добра снимка и ясна наличност.</p>
    </div>
    <a asp-action="Index" class="btn btn-ghost-dark">Назад</a>
</section>

<section class="editor-shell">
    <div class="content-card editor-card compact-editor-card">
        <form asp-action="Create" class="stacked-form">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="editor-section">
                <div class="editor-section-head">
                    <h2>Основни данни</h2>
                    <p>Име, категория и описание на продукта.</p>
                </div>

                <div class="editor-grid editor-grid-wide">
                    <div class="form-group">
                        <label asp-for="Name" class="control-label"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="CategoryId" class="control-label"></label>
                        <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId"></select>
                        <span asp-validation-for="CategoryId" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-group mb-0">
                    <label asp-for="Description" class="control-label"></label>
                    <textarea asp-for="Description" class="form-control form-area" rows="4"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
            </div>

            <div class="editor-section">
                <div class="editor-section-head">
                    <h2>Продажбени данни</h2>
                    <p>Размер, цена, наличност и снимка.</p>
                </div>

                <div class="editor-grid">
                    <div class="form-group">
                        <label asp-for="Size" class="control-label"></label>
                        <input asp-for="Size" class="form-control" />
                        <span asp-validation-for="Size" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Price" class="control-label"></label>
                        <input asp-for="Price" class="form-control" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="StockQuantity" class="control-label"></label>
                        <input asp-for="StockQuantity" class="form-control" min="0" />
                        <span asp-validation-for="StockQuantity" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-group mb-0">
                    <label asp-for="ImageUrl" class="control-label"></label>
                    <input asp-for="ImageUrl" class="form-control" />
                    <span asp-validation-for="ImageUrl" class="text-danger"></span>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-brand">Запиши продукта</button>
                <a asp-action="Index" class="action-link">Отказ</a>
            </div>
        </form>
    </div>

    <aside class="editor-aside">
        <span class="eyebrow">Бележки за каталога</span>
        <h3>Как да стои добре</h3>
        <ul class="editor-tips">
            <li>Кратко силно име, което веднага казва какво е продуктът.</li>
            <li>Снимка с чист фокус върху екипировката.</li>
            <li>Точна цена и реална наличност.</li>
            <li>Описание, което звучи като продукт, не като бележка.</li>
        </ul>
    </aside>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
