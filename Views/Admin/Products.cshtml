@model IEnumerable<ASPMMA.Data.Product>

@{
    ViewData["Title"] = "Админ продукти";
    var products = Model.ToList();
}

<section class="section-head mb-4">
    <div>
        <h1>Продукти</h1>
        <p>Пълен контрол върху каталога от админ панела.</p>
    </div>
    <a asp-controller="Products" asp-action="Create" class="btn btn-brand">Добави продукт</a>
</section>

<partial name="_AdminNav" />

<section class="content-card">
    <div class="table-shell">
        <table class="table-dark-card">
            <thead>
                <tr>
                    <th>Продукт</th>
                    <th>Категория</th>
                    <th>Цена</th>
                    <th>Наличност</th>
                    <th class="text-end">Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in products)
                {
                    <tr>
                        <td>
                            <div class="product-cell">
                                <img src="@(string.IsNullOrWhiteSpace(product.ImageUrl) ? "https://images.unsplash.com/photo-1517838277536-f5f99be501cd?auto=format&fit=crop&w=300&q=80" : product.ImageUrl)" alt="@product.Name" class="avatar-square" />
                                <div>
                                    <span class="product-name">@product.Name</span>
                                    <span class="product-sub">@product.CatalogNumber</span>
                                </div>
                            </div>
                        </td>
                        <td><span class="badge-date">@product.Categorys?.CategoryName</span></td>
                        <td><span class="price-tag">@product.Price.ToString("0.##") лв.</span></td>
                        <td><span class="badge-stock">@product.StockQuantity бр.</span></td>
                        <td>
                            <div class="actions-wrap justify-content-end">
                                <a asp-controller="Products" asp-action="Details" asp-route-id="@product.Id" class="action-link">Детайли</a>
                                <a asp-controller="Products" asp-action="Edit" asp-route-id="@product.Id" class="action-link">Редакция</a>
                                <a asp-controller="Products" asp-action="Delete" asp-route-id="@product.Id" class="action-link danger-soft">Изтрий</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
