@model ASPMMA.Data.Order
@using ASPMMA.Data

@{
    ViewData["Title"] = "Изтриване на поръчка";
    var total = (Model.Products?.Price ?? 0) * Model.Quantity;
}

<section class="section-head mb-4">
    <div>
        <h1>Изтриване на поръчка</h1>
        <p>Поръчка #@Model.Id · @Model.Status.GetLabel()</p>
    </div>
    <a asp-controller="Admin" asp-action="Orders" class="btn btn-ghost-dark">Назад</a>
</section>

<section class="content-card danger-card">
    <span class="eyebrow">Потвърждение</span>
    <h2>Изтриване на тази поръчка?</h2>
    <p class="form-note">@Model.Products?.Name, @Model.Quantity бр., общо @total.ToString("0.##") лв. за @Model.Clients?.UserName.</p>

    <form asp-action="Delete" class="form-actions">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Изтрий поръчката</button>
        <a asp-controller="Admin" asp-action="Orders" class="action-link">Отказ</a>
    </form>
</section>
