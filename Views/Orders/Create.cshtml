@model ASPMMA.Data.Order
@using ASPMMA.Data

@{
    ViewData["Title"] = "Нова поръчка";
}

<section class="section-head mb-4">
    <div>
        <h1>Нова поръчка</h1>
        <p>Ръчно създаване на поръчка за конкретен клиент.</p>
    </div>
    <a asp-controller="Admin" asp-action="Orders" class="btn btn-ghost-dark">Назад</a>
</section>

<section class="content-card editor-card">
    <form asp-action="Create" class="stacked-form">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="form-grid">
            <div class="form-group">
                <label asp-for="ClientId" class="control-label">Клиент</label>
                <select asp-for="ClientId" class="form-select" asp-items="ViewBag.ClientId"></select>
                <span asp-validation-for="ClientId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ProductId" class="control-label">Продукт</label>
                <select asp-for="ProductId" class="form-select" asp-items="ViewBag.ProductId"></select>
                <span asp-validation-for="ProductId" class="text-danger"></span>
            </div>
        </div>

        <div class="form-grid">
            <div class="form-group">
                <label asp-for="Quantity" class="control-label">Количество</label>
                <input asp-for="Quantity" class="form-control" min="1" />
                <span asp-validation-for="Quantity" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Status" class="control-label">Статус</label>
                <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<OrderStatus>()"></select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-brand">Създай поръчка</button>
            <a asp-controller="Admin" asp-action="Orders" class="action-link">Отказ</a>
        </div>
    </form>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
