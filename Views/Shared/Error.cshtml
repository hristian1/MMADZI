@model ErrorViewModel
@{
    ViewData["Title"] = "Грешка";
}

<section class="content-card danger-card">
    <span class="eyebrow">Грешка</span>
    <h1 class="text-danger">Възникна грешка.</h1>
    <p class="form-note">Заявката не можа да бъде обработена.</p>

    @if (Model.ShowRequestId)
    {
        <p>
            <strong>Номер на заявката:</strong> <code>@Model.RequestId</code>
        </p>
    }
</section>
