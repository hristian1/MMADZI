@using ASPMMA.Data
@using Microsoft.AspNetCore.Identity
@inject SignInManager<Client> SignInManager
@inject UserManager<Client> UserManager

<ul class="navbar-nav align-items-lg-center gap-2 auth-menu">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        <a class="user-chip" asp-area="Identity" asp-page="/Account/Manage/Index" title="Профил">@User.Identity?.Name</a>
    </li>
    <li class="nav-item">
        <form class="m-0" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="submit" class="btn btn-ghost-dark btn-sm">Изход</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="btn btn-ghost-dark btn-sm" asp-area="Identity" asp-page="/Account/Register">Регистрация</a>
    </li>
    <li class="nav-item">
        <a class="btn btn-brand btn-sm" asp-area="Identity" asp-page="/Account/Login">Вход</a>
    </li>
}
</ul>
