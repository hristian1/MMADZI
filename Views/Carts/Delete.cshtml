@model ASPMMA.Data.Cart

@{
    ViewData["Title"] = "Премахване от количка";
    var total = (Model.Products?.Price ?? 0) * Model.Quantity;
}

<section class="section-head mb-4">
    <div>
        <h1>Премахване от количка</h1>
        <p>Потвърди премахването на запис #@Model.Id.</p>
    </div>
    <a asp-action="Index" class="btn btn-ghost-dark">Назад</a>
</section>

<section class="content-card danger-card">
    <span class="eyebrow">Потвърждение</span>
    <h2>Да премахнем ли този продукт?</h2>
    <p class="form-note">@Model.Products?.Name, @Model.Quantity бр., стойност @total.ToString("0.##") лв. за @Model.Clients?.UserName.</p>

    <form asp-action="Delete" class="form-actions">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Премахни от количката</button>
        <a asp-action="Index" class="action-link">Отказ</a>
    </form>
</section>
