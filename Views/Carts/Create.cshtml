@model ASPMMA.Data.Cart

@{
    ViewData["Title"] = "Ново добавяне в количка";
}

<section class="section-head mb-4">
    <div>
        <h1>Ново добавяне в количка</h1>
        <p>Добави продукт и количество към количката на текущия админ профил.</p>
    </div>
    <a asp-action="Index" class="btn btn-ghost-dark">Назад</a>
</section>

<section class="content-card editor-card">
    <form asp-action="Create" class="stacked-form">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="form-grid">
            <div class="form-group">
                <label asp-for="ProductId" class="control-label">Продукт</label>
                <select asp-for="ProductId" class="form-control" asp-items="ViewBag.ProductId"></select>
            </div>
            <div class="form-group">
                <label asp-for="Quantity" class="control-label">Количество</label>
                <input asp-for="Quantity" class="form-control" min="1" />
                <span asp-validation-for="Quantity" class="text-danger"></span>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-brand">Добави в количката</button>
            <a asp-action="Index" class="action-link">Отказ</a>
        </div>
    </form>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
