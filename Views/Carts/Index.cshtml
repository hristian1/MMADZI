@model IEnumerable<ASPMMA.Data.Cart>

@{
    ViewData["Title"] = "Количка";
    var carts = Model?.ToList() ?? new List<ASPMMA.Data.Cart>();
    var totalQuantity = carts.Sum(x => x.Quantity);
    var totalPrice = carts.Sum(x => (x.Products?.Price ?? 0) * x.Quantity);
}

<section class="section-head mb-4">
    <div>
        <h1>Количка</h1>
        <p>Избраните от клиента продукти се визуализират с единични цени, количества и обща стойност.</p>
    </div>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-brand rounded-pill px-4">Ръчно добавяне</a>
    }
</section>

@if (TempData["CartError"] is string cartError)
{
    <div class="alert alert-danger mb-4">@cartError</div>
}

@if (TempData["CartSuccess"] is string cartSuccess)
{
    <div class="alert alert-success mb-4">@cartSuccess</div>
}

@if (!User.Identity?.IsAuthenticated ?? true)
{
    <section class="content-card">
        <div class="empty-state">
            <h3 class="mb-2 text-white">Количката е достъпна за регистрирани клиенти</h3>
            <p class="mb-3">Влез в профила си, за да добавяш продукти и да създаваш поръчки.</p>
            <div class="actions-wrap justify-content-center">
                <a asp-area="Identity" asp-page="/Account/Login" asp-route-returnUrl="@Url.Action("Index", "Carts")" class="btn btn-brand">Вход</a>
                <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-ghost-dark">Регистрация</a>
            </div>
        </div>
    </section>
}
else
{
    <section class="metric-grid">
        <article class="metric-card">
            <h3>@carts.Count</h3>
            <p>Редове в количката</p>
        </article>
        <article class="metric-card">
            <h3>@totalQuantity</h3>
            <p>Общо количество</p>
        </article>
        <article class="metric-card">
            <h3>@totalPrice.ToString("0.##") лв.</h3>
            <p>Обща стойност</p>
        </article>
        <article class="metric-card">
            <h3>@(carts.Any() ? carts.Max(x => x.CreatedAt).ToString("dd.MM") : "-")</h3>
            <p>Последно добавяне</p>
        </article>
    </section>

    <section class="content-card">
        <div class="table-shell">
            @if (carts.Any())
            {
                <table class="table-dark-card">
                    <thead>
                        <tr>
                            <th>Продукт</th>
                            <th>Ед. цена</th>
                            <th>Количество</th>
                            <th>Общо</th>
                            <th>Добавено</th>
                            <th class="text-end">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in carts)
                        {
                            var imageUrl = string.IsNullOrWhiteSpace(item.Products?.ImageUrl)
                                ? "https://images.unsplash.com/photo-1517438476312-10d79c077509?auto=format&fit=crop&w=300&q=80"
                                : item.Products.ImageUrl;
                            var rowTotal = (item.Products?.Price ?? 0) * item.Quantity;

                            <tr>
                                <td>
                                    <div class="product-cell">
                                        <img src="@imageUrl" alt="@item.Products?.Name" class="avatar-square" />
                                        <div>
                                            <span class="product-name">@item.Products?.Name</span>
                                            <span class="product-sub">@item.Products?.CatalogNumber · @(item.Products?.Categorys?.CategoryName ?? "")</span>
                                        </div>
                                    </div>
                                </td>
                                <td><span class="price-tag">@((item.Products?.Price ?? 0).ToString("0.##")) лв.</span></td>
                                <td><span class="badge-stock">@item.Quantity бр.</span></td>
                                <td><span class="price-tag">@rowTotal.ToString("0.##") лв.</span></td>
                                <td><span class="badge-date">@item.CreatedAt.ToString("dd.MM.yyyy")</span></td>
                                <td>
                                    <div class="actions-wrap justify-content-end">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="action-link">Редакция</a>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="action-link">Детайли</a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="action-link danger-soft">Премахни</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <div class="checkout-bar">
                    <div>
                        <h3>Обща сума: @totalPrice.ToString("0.##") лв.</h3>
                        <p class="mb-0 text-white-50">След финализиране на поръчката наличностите се намаляват автоматично.</p>
                    </div>
                    <form asp-action="PlaceOrder" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-brand btn-lg">Поръчай</button>
                    </form>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <h3 class="mb-2 text-white">Количката е празна</h3>
                    <p class="mb-3">Добави продукти от каталога, за да подготвиш клиентска поръчка.</p>
                    <a asp-controller="Products" asp-action="Index" class="btn btn-brand rounded-pill px-4">Към продуктите</a>
                </div>
            }
        </div>
    </section>
}
