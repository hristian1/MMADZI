@model ASPMMA.Models.HomeViewModel

@{
    ViewData["Title"] = "Начало";
    var featured = Model.FeaturedProducts.ToList();
    var categories = Model.Categories.ToList();
}

<section class="home-hero">
    <div class="home-hero-grid">
        <div class="hero-panel">
            <span class="hero-kicker">ММА екипировка</span>
            <h1 class="hero-title">Ръкавици, шорти, протектори и екипировка за тренировки, спаринг и седмица на боя.</h1>
            <p class="hero-text">Тежък стил, чист каталог и оборудване, което изглежда готово за клетката още преди да си отворил продукта.</p>

            <div class="home-hero-actions">
                <a asp-controller="Products" asp-action="Index" class="btn btn-brand btn-lg">Пазарувай сега</a>
                <a asp-controller="Categories" asp-action="Index" class="btn btn-ghost-dark btn-lg">Виж категориите</a>
            </div>

            <div class="hero-points">
                <div>
                    <strong>Ръкавици</strong>
                    <span>Тренировки, спаринг, състезания</span>
                </div>
                <div>
                    <strong>Протектори</strong>
                    <span>Кори, протектори за уста, бинтове</span>
                </div>
                <div>
                    <strong>Облекло</strong>
                    <span>Шорти, рашгарди, визия за излизане</span>
                </div>
            </div>
        </div>

        <aside class="hero-gear-board">
            <div class="hero-gear-card main">
                <img src="~/images/mma-top-hero.jpg" alt="ММА бойци" class="hero-gear-image" />
            </div>
            <div class="hero-gear-strip">
                <div>
                    <strong>01</strong>
                    <span>Удари</span>
                </div>
                <div>
                    <strong>02</strong>
                    <span>Граплинг</span>
                </div>
                <div>
                    <strong>03</strong>
                    <span>Защита</span>
                </div>
            </div>
        </aside>
    </div>
</section>

<section class="metric-grid">
    <article class="metric-card">
        <h3>@featured.Count</h3>
        <p>Акценти в каталога</p>
    </article>
    <article class="metric-card">
        <h3>@categories.Count</h3>
        <p>Ключови категории</p>
    </article>
    <article class="metric-card">
        <h3>@featured.Count(x => x.StockQuantity > 0)</h3>
        <p>Налични артикули</p>
    </article>
    <article class="metric-card">
        <h3>@(featured.Any() ? $"{featured.Max(x => x.Price):0.##} лв." : "0 лв.")</h3>
        <p>Премиум селекция</p>
    </article>
</section>

@if (categories.Any())
{
    <section class="home-band">
        <div class="section-head">
            <div>
                <h2>Категории на преден план</h2>
                <p>От удари и защита до пълен тренировъчен комплект.</p>
            </div>
            <a asp-controller="Categories" asp-action="Index" class="action-link">Всички категории</a>
        </div>

        <div class="category-showcase">
            @foreach (var category in categories)
            {
                <a asp-controller="Products" asp-action="Index" asp-route-categoryId="@category.Id" class="category-showcase-card">
                    <span class="badge-soft">@category.Products.Count продукта</span>
                    <h3>@category.CategoryName</h3>
                    <p>@category.Description</p>
                </a>
            }
        </div>
    </section>
}

@if (featured.Any())
{
    <section class="home-band">
        <div class="section-head">
            <div>
                <h2>Избрани продукти</h2>
                <p>Фокус върху визия, наличност и бързо добавяне в количка.</p>
            </div>
            <a asp-controller="Products" asp-action="Index" class="action-link">Към каталога</a>
        </div>

        <div class="product-grid">
            @foreach (var product in featured)
            {
                <article class="shop-card">
                    <img src="@(string.IsNullOrWhiteSpace(product.ImageUrl) ? "https://images.unsplash.com/photo-1517838277536-f5f99be501cd?auto=format&fit=crop&w=800&q=80" : product.ImageUrl)" alt="@product.Name" class="shop-card-image" />
                    <div class="shop-card-body">
                        <span class="badge-soft">@product.CatalogNumber</span>
                        <h3>@product.Name</h3>
                        <p class="product-sub">@product.Description</p>
                        <div class="shop-meta">
                            <span class="badge-date">@product.Categorys?.CategoryName</span>
                            <span class="price-tag">@product.Price.ToString("0.##") лв.</span>
                        </div>
                        <div class="actions-wrap mt-3">
                            <a asp-controller="Products" asp-action="Details" asp-route-id="@product.Id" class="action-link">Детайли</a>
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <form asp-controller="Carts" asp-action="AddToCart" method="post" class="inline-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@product.Id" />
                                    <input type="hidden" name="quantity" value="1" />
                                    <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                    <button type="submit" class="btn btn-brand btn-sm">Добави в количка</button>
                                </form>
                            }
                        </div>
                    </div>
                </article>
            }
        </div>
    </section>
}
