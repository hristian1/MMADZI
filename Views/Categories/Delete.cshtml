@model ASPMMA.Data.Category

@{
    ViewData["Title"] = "Изтриване на категория";
}

<section class="section-head mb-4">
    <div>
        <h1>Изтриване на категория</h1>
        <p>Потвърди изтриването на тази категория от каталога.</p>
    </div>
    <a asp-action="Index" class="btn btn-ghost-dark">Назад</a>
</section>

<section class="content-card danger-card">
    <span class="eyebrow">Потвърждение</span>
    <h2>@Model.CategoryName</h2>
    <p class="form-note">@Model.Description</p>

    <form asp-action="Delete" class="form-actions">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Изтрий категорията</button>
        <a asp-action="Index" class="action-link">Отказ</a>
    </form>
</section>
