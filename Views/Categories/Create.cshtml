@model ASPMMA.Data.Category

@{
    ViewData["Title"] = "Добавяне на категория";
}

<section class="section-head mb-4">
    <div>
        <span class="hero-kicker">Админ редактор</span>
        <h1>Добавяне на категория</h1>
        <p>Създай ясна група за продуктите, така че каталогът да се чете бързо и подредено.</p>
    </div>
    <a asp-action="Index" class="btn btn-ghost-dark">Назад</a>
</section>

<section class="editor-shell category-editor-shell">
    <div class="content-card editor-card compact-editor-card">
        <form asp-action="Create" class="stacked-form">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="editor-section">
                <div class="editor-section-head">
                    <h2>Категория</h2>
                    <p>Името трябва да е кратко, а описанието да подсказва каква екипировка стои вътре.</p>
                </div>

                <div class="form-group">
                    <label asp-for="CategoryName" class="control-label"></label>
                    <input asp-for="CategoryName" class="form-control" />
                    <span asp-validation-for="CategoryName" class="text-danger"></span>
                </div>

                <div class="form-group mb-0">
                    <label asp-for="Description" class="control-label"></label>
                    <textarea asp-for="Description" class="form-control form-area" rows="4"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-brand">Запиши категорията</button>
                <a asp-action="Index" class="action-link">Отказ</a>
            </div>
        </form>
    </div>

    <aside class="editor-aside category-preview-aside">
        <span class="eyebrow">Карта на категорията</span>
        <h3>Нова MMA секция</h3>
        <p class="form-note">Категорията ще се появи в каталога като отделна карта и ще може да събира продукти като ръкавици, протектори, шорти или аксесоари.</p>

        <div class="category-preview-card">
            <span class="badge-soft">Нова категория</span>
            <strong>Бойна екипировка</strong>
            <span>Готова за продукти</span>
        </div>
    </aside>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
