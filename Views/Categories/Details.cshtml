@model ASPMMA.Data.Category

@{
    ViewData["Title"] = "Детайли за категория";
}

<section class="section-head mb-4">
    <div>
        <h1>@Model.CategoryName</h1>
        <p>@Model.Description</p>
    </div>
    <div class="actions-wrap">
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-brand">Редакция</a>
        }
        <a asp-action="Index" class="btn btn-ghost-dark">Назад</a>
    </div>
</section>

<section class="content-card mb-4">
    <div class="section-head">
        <div>
            <h2>Продукти в категорията</h2>
            <p>Извличане на всички продукти по избрана категория.</p>
        </div>
    </div>

    @if (Model.Products.Any())
    {
        <div class="product-grid">
            @foreach (var product in Model.Products)
            {
                <article class="shop-card">
                    <div class="shop-card-body">
                        <span class="badge-soft">@product.CatalogNumber</span>
                        <h3>@product.Name</h3>
                        <p class="product-sub">@product.Description</p>
                        <div class="shop-meta">
                            <span class="price-tag">@product.Price.ToString("0.##") лв.</span>
                            <span class="badge-stock">@product.StockQuantity бр.</span>
                        </div>
                        <div class="actions-wrap mt-3">
                            <a asp-controller="Products" asp-action="Details" asp-route-id="@product.Id" class="action-link">Виж продукта</a>
                        </div>
                    </div>
                </article>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <h3 class="mb-2 text-white">Няма продукти в тази категория</h3>
            <p class="mb-0">Категорията е създадена, но все още няма добавени артикули.</p>
        </div>
    }
</section>
