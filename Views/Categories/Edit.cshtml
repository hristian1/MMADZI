@model ASPMMA.Data.Category

@{
    ViewData["Title"] = "Редакция на категория";
}

<section class="section-head mb-4">
    <div>
        <span class="hero-kicker">Админ редактор</span>
        <h1>Редакция на категория</h1>
        <p>Обнови името и описанието, без да губиш контекста на каталога.</p>
    </div>
    <a asp-action="Index" class="btn btn-ghost-dark">Назад</a>
</section>

<section class="editor-shell category-editor-shell">
    <div class="content-card editor-card compact-editor-card">
        <form asp-action="Edit" class="stacked-form">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="Id" />

            <div class="editor-section">
                <div class="editor-section-head">
                    <h2>Категория</h2>
                    <p>Дръж текста стегнат, за да изглежда добре и в картите, и във филтрите.</p>
                </div>

                <div class="form-group">
                    <label asp-for="CategoryName" class="control-label"></label>
                    <input asp-for="CategoryName" class="form-control" />
                    <span asp-validation-for="CategoryName" class="text-danger"></span>
                </div>

                <div class="form-group mb-0">
                    <label asp-for="Description" class="control-label"></label>
                    <textarea asp-for="Description" class="form-control form-area" rows="4"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-brand">Запази промените</button>
                <a asp-action="Index" class="action-link">Отказ</a>
            </div>
        </form>
    </div>

    <aside class="editor-aside category-preview-aside">
        <span class="eyebrow">Текуща категория</span>
        <h3>@Model.CategoryName</h3>
        <p class="form-note">@Model.Description</p>

        <div class="editor-meta">
            <div>
                <dt>ID</dt>
                <dd>@Model.Id</dd>
            </div>
            <div>
                <dt>Тип</dt>
                <dd>Каталог</dd>
            </div>
        </div>
    </aside>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
