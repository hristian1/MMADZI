@model IEnumerable<ASPMMA.Data.Category>

@{
    ViewData["Title"] = "Категории";
    var categories = Model?.ToList() ?? new List<ASPMMA.Data.Category>();
}

<section class="section-head mb-4">
    <div>
        <h1>Категории</h1>
        <p>Публичен каталог за разглеждане на продуктите по избрана категория.</p>
    </div>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-brand rounded-pill px-4">Добави категория</a>
    }
</section>

<section class="metric-grid">
    <article class="metric-card">
        <h3>@categories.Count</h3>
        <p>Общ брой категории</p>
    </article>
    <article class="metric-card">
        <h3>@categories.Sum(x => x.Products.Count)</h3>
        <p>Продукти в категориите</p>
    </article>
    <article class="metric-card">
        <h3>@categories.Count(x => x.Products.Any())</h3>
        <p>Категории с продукти</p>
    </article>
    <article class="metric-card">
        <h3>@(categories.Any() ? "Готово" : "Старт")</h3>
        <p>Състояние на каталога</p>
    </article>
</section>

<section class="product-grid">
    @foreach (var item in categories)
    {
        <article class="shop-card">
            <div class="shop-card-body">
                <span class="badge-soft">ID: @item.Id</span>
                <h3>@item.CategoryName</h3>
                <p class="product-sub">@item.Description</p>
                <div class="shop-meta">
                    <span class="badge-stock">@item.Products.Count продукта</span>
                </div>
                <div class="actions-wrap mt-3">
                    <a asp-controller="Products" asp-action="Index" asp-route-categoryId="@item.Id" class="btn btn-brand btn-sm">Виж продукти</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="action-link">Детайли</a>
                </div>
                @if (User.IsInRole("Admin"))
                {
                    <div class="actions-wrap mt-2">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="action-link">Редакция</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="action-link danger-soft">Изтрий</a>
                    </div>
                }
            </div>
        </article>
    }
</section>
